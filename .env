QUERY1 = SELECT AD.Associate_ID, AD.Associate_FirstName, AD.Associate_LastName, AD.Associate_MiddleInitial, AD.MonthsOfExp, AD.DateOfJoining, AD.Jobcode, AP.Grade, AP.Designation, STRING_AGG(CAST(ASP.SkillName AS NVARCHAR(MAX)), ' / ') AS SkillName FROM CentralRepository.dbo.vw_CentralRepository_Associate_Details AD (NOLOCK) INNER JOIN PEG_AssociateMarketPlace.dbo.txn_associateprofile AP (NOLOCK) ON AD.Associate_ID = AP.AssociateId INNER JOIN PEG_AssociateMarketPlace.dbo.Txn_AssociateSkills ASP (NOLOCK) ON AD.Associate_ID = ASP.AssociateId WHERE AD.IsActive = 'A' group by AD.Associate_ID, AD.Associate_FirstName, AD.Associate_LastName, AD.Associate_MiddleInitial, AD.MonthsOfExp, AD.DateOfJoining, AD.Jobcode, AP.Grade, AP.Designation;
QUERY2 = select SOId,STRING_AGG(CAST(SkillName AS NVARCHAR(MAX)), ' / ') AS SO_Skills from PEG_AssociateMarketPlace..Txn_ServiceOrderSkillDetails with (nolock) group by SOId
